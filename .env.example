# Intel-Flow Configuration Example (2026)
# Copy this file to .env.local for local development.

# AI Analysis
GEMINI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AI_MODEL=gemini-2.5-flash
ENABLE_AI_ANALYSIS=false

# News / Community Sources
NEWS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AI_GITHUB_RELEASE_REPOS=openai/openai-python,anthropics/anthropic-sdk-python,microsoft/autogen,langchain-ai/langchain,crewAIInc/crewAI,huggingface/transformers

# Deliverers
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxxxxxx/xxxxxxxx
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_PAGE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ENABLE_DISCORD_DELIVERY=false
ENABLE_NOTION_DELIVERY=false

# Safety Defaults
DRY_RUN=true
USE_FIXTURE_DATA=false
ENABLE_HISTORY_DEDUP=false
WRITE_ARTIFACTS=true

# App Settings
INTERVAL_MINUTES=15
MAX_DESC_LENGTH=220
STOCK_NEWS_LOOKBACK_DAYS=7
AI_NEWS_LOOKBACK_DAYS=14
HISTORY_LIMIT=2000
HISTORY_TTL_HOURS=12
STATE_FILE=data/run_state.json
ARTIFACT_FILE=data/latest_run.json
US_STOCKS=NVDA,TSLA,AMD,GOOG,AAPL
TW_STOCKS=0050,2330,00692
TW_STOCK_SOURCE_ORDER=yfinance,mis
